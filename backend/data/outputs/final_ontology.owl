<?xml version="1.0"?>
<rdf:RDF
  xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
  xmlns:owl="http://www.w3.org/2002/07/owl#"
  xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
  xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
  xmlns:sle="http://example.org/sle#">

<owl:Ontology rdf:about="http://example.org/sle#" />

  <owl:Class rdf:about="http://example.org/sle#Learner">
    <rdfs:label>Learner</rdfs:label>
    <rdfs:comment>A learner in the SLE</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="http://example.org/sle#Teacher">
    <rdfs:label>Teacher</rdfs:label>
    <rdfs:comment>A teacher in the SLE</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="http://example.org/sle#LearningSystem">
    <rdfs:label>LearningSystem</rdfs:label>
    <rdfs:comment>The system that supports learning in the SLE</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="http://example.org/sle#LearningActivity">
    <rdfs:label>LearningActivity</rdfs:label>
    <rdfs:comment>An activity that takes place in the SLE</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://example.org/sle#LearningSystem"/>
  </owl:Class>

  <owl:Class rdf:about="http://example.org/sle#LearningResource">
    <rdfs:label>LearningResource</rdfs:label>
    <rdfs:comment>A resource used in the SLE</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="http://example.org/sle#LearningAnalytics">
    <rdfs:label>LearningAnalytics</rdfs:label>
    <rdfs:comment>Data collected on learning in the SLE</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="http://example.org/sle#Learning System">
    <rdfs:label>Learning System</rdfs:label>
    <rdfs:comment>The infrastructure and technology that supports learning activities.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="http://example.org/sle#Learning Activity">
    <rdfs:label>Learning Activity</rdfs:label>
    <rdfs:comment>A specific task or project that learners engage in to acquire knowledge or skills.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://example.org/sle#Learning System"/>
  </owl:Class>

  <owl:Class rdf:about="http://example.org/sle#Learning Resource">
    <rdfs:label>Learning Resource</rdfs:label>
    <rdfs:comment>A material, tool, or technology used to support learning activities.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://example.org/sle#Learning System"/>
  </owl:Class>

  <owl:Class rdf:about="http://example.org/sle#Learning Analytics">
    <rdfs:label>Learning Analytics</rdfs:label>
    <rdfs:comment>The process of analyzing data from learning activities to inform instruction and improve student outcomes.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://example.org/sle#Learning System"/>
  </owl:Class>

  <owl:ObjectProperty rdf:about="http://example.org/sle#interactsWith">
    <rdfs:label>interactsWith</rdfs:label>
    <rdfs:comment>A learner interacts with a learning activity</rdfs:comment>
    <rdfs:domain rdf:resource="http://example.org/sle#LearnerLearningActivity"/>
    <rdfs:range rdf:resource="http://example.org/sle#LearningActivity"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://example.org/sle#participatesIn">
    <rdfs:label>participatesIn</rdfs:label>
    <rdfs:comment>A teacher participates in a learning activity</rdfs:comment>
    <rdfs:domain rdf:resource="http://example.org/sle#TeacherLearningActivity"/>
    <rdfs:range rdf:resource="http://example.org/sle#LearningActivity"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://example.org/sle#usesResource">
    <rdfs:label>usesResource</rdfs:label>
    <rdfs:comment>A learner uses a learning resource</rdfs:comment>
    <rdfs:domain rdf:resource="http://example.org/sle#LearnerLearningResource"/>
    <rdfs:range rdf:resource="http://example.org/sle#LearningResource"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://example.org/sle#supports">
    <rdfs:label>supports</rdfs:label>
    <rdfs:comment>A teacher supports a learner</rdfs:comment>
    <rdfs:domain rdf:resource="http://example.org/sle#TeacherLearner"/>
    <rdfs:range rdf:resource="http://example.org/sle#Learner"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://example.org/sle#monitors">
    <rdfs:label>monitors</rdfs:label>
    <rdfs:comment>The learning system monitors learning analytics</rdfs:comment>
    <rdfs:domain rdf:resource="http://example.org/sle#LearningSystemLearningAnalytics"/>
    <rdfs:range rdf:resource="http://example.org/sle#LearningAnalytics"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://example.org/sle#adaptsTo">
    <rdfs:label>adaptsTo</rdfs:label>
    <rdfs:comment>The learning system adapts to a learner's needs</rdfs:comment>
    <rdfs:domain rdf:resource="http://example.org/sle#LearningSystemLearner"/>
    <rdfs:range rdf:resource="http://example.org/sle#Learner"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://example.org/sle#interactsWith">
    <rdfs:label>interactsWith</rdfs:label>
    <rdfs:comment>The learner is engaged in the learning activity.</rdfs:comment>
    <rdfs:domain rdf:resource="http://example.org/sle#Learner"/>
    <rdfs:range rdf:resource="http://example.org/sle#LearningActivity"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://example.org/sle#participatesIn">
    <rdfs:label>participatesIn</rdfs:label>
    <rdfs:comment>The learner is involved in the learning activity.</rdfs:comment>
    <rdfs:domain rdf:resource="http://example.org/sle#Learner"/>
    <rdfs:range rdf:resource="http://example.org/sle#LearningActivity"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://example.org/sle#usesResource">
    <rdfs:label>usesResource</rdfs:label>
    <rdfs:comment>The learner uses the resource to support their learning.</rdfs:comment>
    <rdfs:domain rdf:resource="http://example.org/sle#Learner"/>
    <rdfs:range rdf:resource="http://example.org/sle#LearningResource"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://example.org/sle#supports">
    <rdfs:label>supports</rdfs:label>
    <rdfs:comment>The teacher provides support for the learning activity.</rdfs:comment>
    <rdfs:domain rdf:resource="http://example.org/sle#Teacher"/>
    <rdfs:range rdf:resource="http://example.org/sle#LearningActivity"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://example.org/sle#monitors">
    <rdfs:label>monitors</rdfs:label>
    <rdfs:comment>The system monitors the progress of the learning activity.</rdfs:comment>
    <rdfs:domain rdf:resource="http://example.org/sle#LearningSystem"/>
    <rdfs:range rdf:resource="http://example.org/sle#LearningActivity"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://example.org/sle#adaptsTo">
    <rdfs:label>adaptsTo</rdfs:label>
    <rdfs:comment>The system adapts to the learner's needs and abilities.</rdfs:comment>
    <rdfs:domain rdf:resource="http://example.org/sle#LearningSystem"/>
    <rdfs:range rdf:resource="http://example.org/sle#Learner"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://example.org/sle#participatesIn">
    <rdfs:label>participatesIn</rdfs:label>
    <rdfs:comment>The learner participates in the learning activity.</rdfs:comment>
    <rdfs:domain rdf:resource="http://example.org/sle#LearnerLearningActivity"/>
    <rdfs:range rdf:resource="http://example.org/sle#LearningActivity"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://example.org/sle#usesResource">
    <rdfs:label>usesResource</rdfs:label>
    <rdfs:comment>The learner uses a resource to support their learning.</rdfs:comment>
    <rdfs:domain rdf:resource="http://example.org/sle#LearnerLearningActivity"/>
    <rdfs:range rdf:resource="http://example.org/sle#LearningResource"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://example.org/sle#monitors">
    <rdfs:label>monitors</rdfs:label>
    <rdfs:comment>The learning system tracks learner progress and performance.</rdfs:comment>
    <rdfs:domain rdf:resource="http://example.org/sle#LearningSystemLearningActivity"/>
    <rdfs:range rdf:resource="http://example.org/sle#LearningAnalytics"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://example.org/sle#monitors">
    <rdfs:label>monitors</rdfs:label>
    <rdfs:comment>The learning system monitors the progress of a specific learning activity.</rdfs:comment>
    <rdfs:domain rdf:resource="http://example.org/sle#LearningSystemLearningActivity"/>
    <rdfs:range rdf:resource="http://example.org/sle#LearningActivity"/>
  </owl:ObjectProperty>
</rdf:RDF>